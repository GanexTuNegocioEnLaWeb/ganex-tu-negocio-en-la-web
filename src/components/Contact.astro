---
import { siteData } from "../data/siteData";
---
<section id="soporte" class="relative bg-white overflow-hidden py-24">
  <!-- Background decoration -->
  <div class="absolute top-0 left-0 w-full h-full bg-neutral-50 -z-10"></div>
  <div
    class="absolute top-0 right-0 w-1/2 h-full bg-[#FFF4E5] rounded-l-full blur-3xl opacity-60 -z-10"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-96 h-96 bg-emerald-50 rounded-full blur-3xl opacity-60 -z-10"
  >
  </div>

  <div
    class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-start"
  >
    <!-- Left Column: Info -->
    <div>
      <span
        class="text-[#FF8A00] font-bold tracking-wider uppercase text-sm mb-2 block bg-orange-100 w-fit px-3 py-1 rounded-full"
        >Contáctanos</span
      >
      <h2
        class="text-4xl md:text-5xl font-extrabold text-neutral-800 mb-6 leading-tight"
      >
        Tu próximo <span class="text-[#FF8A00]"
          >gran proyecto</span
        >
      </h2>
      <p class="text-lg text-neutral-600 mb-12 leading-relaxed">
        Estamos listos para ayudarte a transformar tus ideas en realidad
        digital. Cuéntanos tus objetivos y te responderemos con una propuesta
        personalizada en menos de 12 horas.
      </p>

      <div class="space-y-8">
        <div
          class="flex items-start gap-5 p-6 bg-white rounded-2xl shadow-sm border border-neutral-100 hover:shadow-md transition-shadow"
        >
          <div
            class="w-14 h-14 bg-orange-50 rounded-full flex items-center justify-center text-[#FF8A00] shrink-0"
          >
            <svg
              class="w-7 h-7"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
          </div>
          <div>
            <h4 class="font-bold text-neutral-800 text-lg mb-1">
              Correo electrónico
            </h4>
            <a
              href={`mailto:${siteData.company.email}`}
              class="text-neutral-600 hover:text-[#FF8A00] transition-colors block text-lg"
              >{siteData.company.email}</a
            >
            <span class="text-xs text-neutral-400 mt-1 block"
              >Respuesta rápida asegurada</span
            >
          </div>
        </div>

        <div
          class="flex items-start gap-5 p-6 bg-white rounded-2xl shadow-sm border border-neutral-100 hover:shadow-md transition-shadow"
        >
          <div
            class="w-14 h-14 bg-emerald-50 rounded-full flex items-center justify-center text-emerald-600 shrink-0"
          >
            <svg
              class="w-7 h-7"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
          </div>
          <div>
            <h4 class="font-bold text-neutral-800 text-lg mb-1">Llámanos</h4>
            <a
              href={siteData.company.phoneLink}
              class="text-neutral-600 hover:text-[#FF8A00] transition-colors block text-lg"
              >{siteData.company.phone}</a
            >
            <span class="text-xs text-neutral-400 mt-1 block"
              >Lun - Vie, 9am - 6pm</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Form -->
    <div
      class="bg-white rounded-4xl shadow-2xl p-8 sm:p-10 border border-neutral-100 relative overflow-hidden"
    >
      <div
        class="absolute top-0 right-0 w-20 h-20 bg-orange-100 rounded-bl-full -mr-10 -mt-10 z-0"
      >
      </div>

      <form id="contact-form" class="space-y-6 relative z-10">
        <h3 class="text-2xl font-bold text-neutral-800 mb-6">
          Envíanos un mensaje
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-neutral-700 ml-1"
              >Nombre</label
            >
            <input
              name="nombre"
              required
              placeholder="Tu nombre"
              class="w-full rounded-xl border border-neutral-200 px-4 py-3.5 focus:outline-none focus:ring-4 focus:ring-orange-100 focus:border-[#FF8A00] transition-all bg-neutral-50 hover:bg-white"
            />
          </div>
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-neutral-700 ml-1"
              >Apellido</label
            >
            <input
              name="apellido"
              placeholder="Tu apellido"
              class="w-full rounded-xl border border-neutral-200 px-4 py-3.5 focus:outline-none focus:ring-4 focus:ring-orange-100 focus:border-[#FF8A00] transition-all bg-neutral-50 hover:bg-white"
            />
          </div>
        </div>

        <div class="space-y-2">
          <label class="block text-sm font-semibold text-neutral-700 ml-1"
            >Correo electrónico</label
          >
          <input
            type="email"
            name="email"
            required
            placeholder="tu@empresa.com"
            class="w-full rounded-xl border border-neutral-200 px-4 py-3.5 focus:outline-none focus:ring-4 focus:ring-orange-100 focus:border-[#FF8A00] transition-all bg-neutral-50 hover:bg-white"
          />
        </div>

        <div class="space-y-2">
          <label class="block text-sm font-semibold text-neutral-700 ml-1"
            >Mensaje</label
          >
          <textarea
            name="mensaje"
            rows="4"
            required
            placeholder="Cuéntanos los detalles de tu proyecto..."
            class="w-full rounded-xl border border-neutral-200 px-4 py-3.5 focus:outline-none focus:ring-4 focus:ring-orange-100 focus:border-[#FF8A00] transition-all bg-neutral-50 hover:bg-white resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-[#FF8A00] text-white font-bold py-4 rounded-xl hover:bg-[#e67e00] transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 transform duration-200 flex items-center justify-center gap-2 group"
        >
          <span>Enviar Mensaje</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 transition-transform group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 5l7 7-7 7M5 12h14"></path>
          </svg>
        </button>
        <p
          id="form-message"
          class="text-center text-sm mt-4 text-neutral-500 min-h-5"
        >
        </p>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById("contact-form");
  const messageEl = document.getElementById("form-message");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    messageEl.textContent = "Enviando...";
    messageEl.className = "mt-4 text-center text-sm text-neutral-600";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      // Simulation
      await new Promise((resolve) => setTimeout(resolve, 1000));
      messageEl.textContent =
        "¡Mensaje enviado con éxito! Nos pondremos en contacto pronto.";
      messageEl.className =
        "mt-4 text-center text-sm text-green-600 font-medium";
      form.reset();
    } catch (error) {
      messageEl.textContent =
        "Hubo un error al enviar el mensaje. Por favor intenta de nuevo.";
      messageEl.className = "mt-4 text-center text-sm text-red-600";
    }
  });
</script>
