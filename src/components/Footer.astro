---
import Image from "astro/components/Image.astro";
import logoGanex from "../assets/logo-ganex.svg";

const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-200 mt-16">
  <div class="max-w-7xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
    <div
      class="flex flex-col md:flex-row md:justify-between md:items-start gap-8"
    >
      <div class="flex flex-col items-start gap-4">
        <Image src={logoGanex} alt="Logo de Ganex" width={180} height={120} />
      </div>

      <p class="text-gray-400 text-sm">
        © {currentYear} Ganex – Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
