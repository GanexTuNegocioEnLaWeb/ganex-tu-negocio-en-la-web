---
import { Image } from "astro:assets";
import { Menu, X } from "@lucide/astro";
import logoGanex from "../assets/logo-ganex-white.svg";
import { siteData } from "../data/siteData";
---

<header class="relative">
  <section
    class="max-w-7xl mx-auto flex items-center justify-between py-6 text-white px-4"
  >
    <!-- Logo -->
    <a href="/" class="w-60 transition-transform hover:scale-105">
      <Image
        src={logoGanex}
        alt="Logo de Ganex"
        width={240}
        height={160}
        class="drop-shadow-lg"
      />
    </a>

    <!-- Desktop menu -->
    <nav class="hidden md:flex gap-10 items-center">
      <section class="relative group">
        <a
          href="/#servicios"
          class="nav-link text-base font-medium hover:text-white/80 transition-colors flex! items-center gap-1"
        >
          Servicios
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform group-hover:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>

        <div
          class="absolute top-full left-0 mt-2 bg-white text-neutral-800 shadow-2xl rounded-xl px-2 py-2 flex flex-col min-w-60
                 opacity-0 scale-95 invisible z-50
                 transition-all duration-200 ease-out
                 group-hover:opacity-100 group-hover:scale-100 group-hover:visible border border-neutral-100 origin-top-left"
        >
          {
            siteData.services.map((service) => (
              <a
                href={service.href}
                class="text-sm text-neutral-600 hover:text-[#FF7A00] hover:bg-orange-50 px-4 py-3 rounded-lg transition-colors font-medium flex items-center justify-between group/item"
              >
                {service.title}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 opacity-0 -translate-x-2 group-hover/item:opacity-100 group-hover/item:translate-x-0 transition-all"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            ))
          }
        </div>
      </section>
      <!-- 
      <a
        href="/#portafolio"
        class="nav-link text-base font-medium hover:text-white/80 transition-colors"
        >Portafolio</a
      > -->

      <a
        href="/sobre-nosotros"
        class="nav-link text-base font-medium hover:text-white/80 transition-colors"
        >Sobre nosotros</a
      >
    </nav>

    <!-- CTA -->
    <a
      href="#soporte"
      class="hidden md:block px-6 py-2.5 bg-white text-[#FF7A00] rounded-full font-bold shadow-lg
             hover:shadow-xl hover:scale-105 transition-all duration-300"
    >
      Contacto & soporte
    </a>

    <!-- Mobile button -->
    <button id="menu-btn" class="md:hidden text-white" aria-label="Abrir menú">
      <Menu size={32} />
    </button>
  </section>

  <!-- Mobile menu -->
</header>

<div
  id="mobile-menu"
  class="fixed z-50! inset-0 bg-[#FF8A00]! flex flex-col items-center justify-center gap-8
         opacity-0 pointer-events-none transition-opacity"
>
  <button id="close-menu" class="absolute top-6 right-6 text-white">
    <X size={32} />
  </button>

  <a
    href="/#servicios"
    class="text-2xl text-white font-medium hover:text-neutral-200 transition-colors"
    >Servicios</a
  >
  <!-- <a
    href="/#portafolio"
    class="text-2xl text-white font-medium hover:text-neutral-200 transition-colors"
    >Portafolio</a
  > -->
  <a
    href="/sobre-nosotros"
    class="text-2xl text-white font-medium hover:text-neutral-200 transition-colors"
    >Sobre nosotros</a
  >
  <a
    href="#soporte"
    class="text-2xl font-bold text-white hover:text-neutral-200 transition-colors"
  >
    Contacto & soporte
  </a>
</div>

<script>
  const btn = document.getElementById("menu-btn");
  const close = document.getElementById("close-menu");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    if (!menu) return;
    menu.classList.remove("opacity-0", "pointer-events-none");
  });

  close?.addEventListener("click", () => {
    if (!menu) return;
    menu.classList.add("opacity-0", "pointer-events-none");
  });
</script>

<style>
  #mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 9999;
  }

  .nav-link {
    position: relative;
    display: inline-block;
    color: #ffffff; /* neutral-800 */
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 2px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-link:hover {
    color: #ffffff;
  }
</style>
