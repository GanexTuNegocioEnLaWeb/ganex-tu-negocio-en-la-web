---
import { siteData } from "../data/siteData";
---

<section id="ubicacion" class="py-24 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-[#FF8A00] font-bold tracking-wider uppercase text-sm mb-2 block">Ubicación</span>
      <h2 class="text-4xl md:text-5xl font-bold text-neutral-800 mb-4">
        Dónde nos <span class="text-[#FF8A00]">encontramos</span>
      </h2>
      <p class="text-xl text-neutral-600 max-w-3xl mx-auto">
        Visítanos en nuestras oficinas o contáctanos para agendar una reunión.
      </p>
    </div>

    <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-neutral-100">
      <div class="relative w-full h-100 sm:h-125 rounded-2xl overflow-hidden">
        <iframe
          src={siteData.company.mapUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="absolute inset-0 w-full h-full"
        ></iframe>
      </div>
    </div>
  </div>
</section>
