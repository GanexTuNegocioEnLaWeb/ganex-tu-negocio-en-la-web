---
import { siteData } from "../data/siteData";
import { Image } from "astro:assets";
---

<section id="portafolio" class="py-24 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-[#FF8A00] font-bold tracking-wider uppercase text-sm mb-2 block">Nuestro Trabajo</span>
      <h2 class="text-4xl md:text-5xl font-bold text-neutral-800 mb-4">
        Proyectos que <span class="text-[#FF8A00]">inspiran</span>
      </h2>
      <p class="text-xl text-neutral-600 max-w-3xl mx-auto">
        Una selección de nuestros trabajos más recientes. Calidad sobre cantidad.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        siteData.portfolio.map((project) => (
          <article class="group relative bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-neutral-100">
            <div class="relative h-64 overflow-hidden bg-neutral-100">
              {/* Placeholder Image if no real image is available */}
               <div class="absolute inset-0 flex items-center justify-center bg-neutral-100 text-neutral-300 group-hover:scale-110 transition-transform duration-500">
                  <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
               </div>
               {/* 
               If you have images, uncomment this and use correct paths
               <Image 
                 src={project.image} 
                 alt={project.title} 
                 width={600} 
                 height={400} 
                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
               /> 
               */}
               <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            
            <div class="p-8">
              <span class="text-xs font-bold text-[#FF8A00] uppercase tracking-wide mb-2 block">
                {project.category}
              </span>
              <h3 class="text-2xl font-bold text-neutral-800 mb-3 group-hover:text-[#FF8A00] transition-colors">
                {project.title}
              </h3>
              <p class="text-neutral-600 mb-6 line-clamp-3">
                {project.description}
              </p>
              
              <a href={project.link} class="inline-flex items-center gap-2 text-neutral-800 font-bold group-hover:text-[#FF8A00] transition-colors">
                Ver Proyecto
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
