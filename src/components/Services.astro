---
const services = [
  {
    title: "Desarrollo web completo",
    description:
      "Creamos sitios web personalizados y optimizados para tu negocio, utilizando las últimas tecnologías y mejores prácticas de la industria.",
    link: "/servicios/desarrollo-web",
    linkText: "Ver más",
    image: "/images/services/web-development.png",
  },
  {
    title: "Desarrollo de aplicaciones",
    description:
      "Desarrollamos aplicaciones móviles y web a medida que se adaptan a las necesidades específicas de tu empresa, garantizando una experiencia de usuario excepcional.",
    link: "/servicios/desarrollo-de-aplicaciones",
    linkText: "Ver más",
    image: "/images/services/app-development.png",
  },
  {
    title: "Chatbots con IA",
    description:
      "Desarrollamos chatbots inteligentes que mejoran la atención al cliente y automatizan procesos, utilizando inteligencia artificial avanzada.",
    link: "/servicios/chatbots-ia",
    linkText: "Ver más",
    image: "/images/services/chatbot.png",
  },
  {
    title: "Marketing digital",
    description:
      "Diseñamos campañas de marketing digital que aumentan el tráfico y las conversiones, utilizando herramientas como Google Ads y redes sociales.",
    link: "/servicios/marketing-digital",
    linkText: "Ver más",
    image: "/images/services/digital-marketing.png",
  },
  {
    title: "Optimización SEO",
    description:
      "Mejoramos la visibilidad de tu sitio web en los motores de búsqueda mediante estrategias de SEO efectivas y personalizadas.",
    link: "/servicios/optimizacion-seo",
    linkText: "Ver más",
    image: "/images/services/seo.png",
  },
];
---

<section id="servicios" class="relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-neutral-800">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-center mb-4">
      Servicios
    </h2>

    <p class="text-center text-base sm:text-lg mb-12">
      Herramientas y soluciones digitales
    </p>

    <ul class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      {
        services.map((service) => (
          <li
            class="h-full px-6 py-8 bg-white rounded-xl
                     flex flex-col sm:flex-row gap-6 items-start
                     shadow-sm transition-all
                     hover:-translate-y-1 hover:shadow-md"
          >
            <img
              src={service.image}
              alt={service.title}
              class="w-24 sm:w-32 h-auto shrink-0"
            />

            <article>
              <h3 class="text-xl sm:text-2xl font-semibold mb-3">
                {service.title}
              </h3>
              <p class="text-base sm:text-lg font-light leading-relaxed">
                {service.description}
              </p>
            </article>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="steps-bottom-bg h-64 sm:h-80 absolute -z-20 w-full -bottom-1">
  </div>
</section>

<style>
  .steps-bottom-bg {
    background: #ff8a00;
    clip-path: polygon(0 100%, 100% 0, 100% 100%, 0 100%);
  }
</style>
