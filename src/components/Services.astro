---
import * as services from "../data/services.json";
---

<section id="servicios" class="relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-neutral-800">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-center mb-4">
      Servicios
    </h2>

    <p class="text-center text-base sm:text-lg mb-12">
      Herramientas y soluciones digitales
    </p>

    <ul class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      {
        services.map((service) => (
          <li
            class="h-full px-6 py-8 bg-white rounded-xl
                     flex flex-col sm:flex-row gap-6 items-start
                     shadow-sm transition-all
                     hover:-translate-y-1 hover:shadow-md"
          >
            <img
              src={service.image}
              alt={service.title}
              class="w-24 sm:w-32 h-auto shrink-0"
            />

            <article>
              <h3 class="text-xl sm:text-2xl font-semibold mb-3">
                {service.title}
              </h3>
              <p class="text-base sm:text-lg font-light leading-relaxed">
                {service.description}
              </p>
            </article>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="steps-bottom-bg h-64 sm:h-80 absolute -z-20 w-full -bottom-1">
  </div>
</section>

<style>
  .steps-bottom-bg {
    background: #ff8a00;
    clip-path: polygon(0 100%, 100% 0, 100% 100%, 0 100%);
  }
</style>
