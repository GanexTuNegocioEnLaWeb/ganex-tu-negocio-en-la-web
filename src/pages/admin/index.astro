                    class="status-filter active px-6 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest transition-all border-2 border-transparent bg-[#FF8A00] text-white shadow-xl shadow-orange-100 active:scale-95 cursor-pointer"
