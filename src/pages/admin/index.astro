                    class="status-filter px-6 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest transition-all border-2 border-neutral-50 bg-white text-neutral-400 hover:border-orange-200 active:scale-95 cursor-pointer"
                    data-status="pending">Pendientes</button
