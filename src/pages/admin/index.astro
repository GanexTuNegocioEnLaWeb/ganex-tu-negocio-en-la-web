                <!-- Dynamically populated -->
            </div>

            <!-- Desktop View: Table -->
            <div
                class="hidden lg:block bg-white rounded-3xl shadow-sm border border-neutral-100 overflow-hidden"
            >
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr
