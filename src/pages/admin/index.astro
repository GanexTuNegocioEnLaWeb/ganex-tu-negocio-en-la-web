                    </div>
                    <h3 class="text-xl font-bold text-neutral-400">
                        Aún no hay leads registrados
                    </h3>
                </div>
                <!-- ) } -->
            </div>
        </div>

        <!-- Modal: Add/Edit Lead -->
        <div
            id="lead-modal"
            class="fixed inset-0 z-50 hidden overflow-y-auto bg-neutral-900/40 backdrop-blur-sm flex items-center justify-center p-4"
        >
            <div
                class="bg-white w-full max-w-xl rounded-3xl shadow-2xl overflow-hidden transform transition-all"
            >
                <div
                    class="px-8 py-6 border-b border-neutral-100 flex justify-between items-center bg-neutral-50/50"
                >
                    <h3
                        id="modal-title"
                        class="text-xl font-bold text-neutral-800"
                    >
                        Añadir Nuevo Lead
                    </h3>
                    <button
                        id="close-modal"
                        class="text-neutral-400 hover:text-neutral-600 cursor-pointer"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-6 h-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>

                <form id="lead-form" class="p-8 space-y-5">
                    <input type="hidden" id="lead-id" name="id" />
                    <input type="hidden" name="country_code" />

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="space-y-2">
                            <label
                                class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                                >Nombre</label
                            >
                            <input
                                type="text"
                                name="name"
                                required
                                placeholder="Ej: Juan Pérez"
                                class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                            />
                        </div>
                        <div class="space-y-2">
                            <label
                                class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                                >WhatsApp</label
                            >
                            <input
                                type="text"
                                name="whatsapp"
                                placeholder="Ej: +591 70000000"
                                class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                            />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="space-y-2">
                            <label
                                class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                                >Email</label
                            >
                            <input
                                type="email"
                                name="email"
                                placeholder="email@ejemplo.com"
                                class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                            />
                        </div>
                        <div class="space-y-2">
                            <label
                                class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                                >Teléfono Alterno</label
                            >
                            <input
                                type="text"
                                name="phone"
                                placeholder="Otro número de contacto"
                                class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                            />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="space-y-2">
                            <label
                                class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                                >Empresa</label
                            >
                            <input
                                type="text"
                                name="company"
                                placeholder="Nombre de la empresa"
                                class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                            />
                        </div>
                        <div class="space-y-2">
                            <label
                                class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                                >Tipo Negocio</label
                            >
                            <input
                                type="text"
                                name="business_type"
                                placeholder="Ej: E-commerce, Local..."
                                class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                            />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="space-y-2">
                            <label
                                class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                                >Servicio Interés</label
                            >
                            <input
                                type="text"
                                name="service"
                                placeholder="Ej: Web Design, SEO..."
                                class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                            />
                        </div>
                        <div class="space-y-2">
                            <label
                                class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                                >Objetivo</label
                            >
                            <input
                                type="text"
                                name="goal"
                                placeholder="Ej: Más ventas, Marca..."
                                class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                            />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label
                            class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                            >Necesidad específica</label
                        >
                        <textarea
                            name="need"
                            rows="2"
                            placeholder="Detalle de la necesidad"
                            class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                        ></textarea>
                    </div>

                    <div class="space-y-2">
                        <label
                            class="text-xs font-bold uppercase text-neutral-400 tracking-wider"
                            >Mensaje / Notas adicionales</label
                        >
                        <textarea
                            name="message"
                            rows="2"
                            placeholder="Notas o mensaje del formulario"
                            class="w-full bg-neutral-50 border border-neutral-100 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all font-medium"
                        ></textarea>
                    </div>

                    <div class="flex gap-4 pt-4">
                        <button
                            type="button"
                            id="cancel-modal"
                            class="grow bg-neutral-100 text-neutral-500 font-bold py-3.5 rounded-xl hover:bg-neutral-200 transition-all cursor-pointer"
                            >Cancelar</button
                        >
                        <button
                            type="submit"
                            id="save-lead-btn"
                            class="grow bg-[#FF8A00] text-white font-bold py-3.5 rounded-xl hover:bg-[#e67e00] transition-all shadow-lg shadow-orange-100 flex items-center justify-center gap-2 cursor-pointer"
                        >
                            <span id="save-btn-text">Guardar Lead</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</Layout>

<script is:inline define:vars={{ leads }}>
    window.INITIAL_LEADS = leads || [];
</script>

<script>
    import { supabase } from "../../lib/supabase";

    // --- Variables & Elements ---
    const modal = document.getElementById("lead-modal");
    const leadForm = document.getElementById("lead-form") as HTMLFormElement;
    const modalTitle = document.getElementById("modal-title");
    const saveBtnText = document.getElementById("save-btn-text");
    const leadsContainerDesktop = document.getElementById(
        "leads-container-desktop",
    );
    const leadsContainerMobile = document.getElementById(
        "leads-container-mobile",
    );
    const totalCountEl = document.getElementById("total-count");
    const noLeadsEl = document.getElementById("no-leads-empty");
    const searchInput = document.getElementById(
        "search-input",
    ) as HTMLInputElement;
    const paginationControls = document.getElementById("pagination-controls");
    const pageRangeEl = document.getElementById("page-range");
    const filteredCountEl = document.getElementById("filtered-count");
    const prevPageBtn = document.getElementById(
        "prev-page",
    ) as HTMLButtonElement;
    const nextPageBtn = document.getElementById(
        "next-page",
    ) as HTMLButtonElement;
    const pageNumbersContainer = document.getElementById("page-numbers");
    const statusFiltersContainer = document.getElementById("status-filters");

    let isEditing = false;
    let leadsData = (window as any).INITIAL_LEADS || [];
    let currentPage = 1;
    let statusFilter = "all";
    const leadsPerPage = 10;
    let filteredLeads = [...leadsData];

    // --- Helpers ---
    const normalizeText = (text: string) => {
        return text
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");
    };

    const debounce = (func: Function, wait: number) => {
        let timeout: any;
        return (...args: any[]) => {
            clearTimeout(timeout);
            timeout = setTimeout(() => func.apply(this, args), wait);
        };
    };

    const extractLeadData = (lead: any) => {
        const details =
            typeof lead.details === "string"
                ? JSON.parse(lead.details)
                : lead.details || {};
        return {
            ...lead,
            service:
                lead.service ||
                details.service ||
                details.service_id ||
                "General",
            goal: lead.goal || details.goal || "-",
            need: lead.need || details.need || "",
            business_type:
                lead.business_type ||
                details.business_type ||
                "No especificado",
            country_code: lead.country_code || details.country_code || "",
        };
    };

    // --- Funciones de Renderizado ---
    const renderLeads = () => {
        const query = normalizeText(searchInput?.value || "");
        const allExtracted = leadsData.map(extractLeadData);

        filteredLeads = allExtracted.filter((lead: any) => {
            const matchesSearch =
                normalizeText(lead.name).includes(query) ||
                (lead.email && normalizeText(lead.email).includes(query)) ||
                (lead.phone && normalizeText(lead.phone).includes(query)) ||
                (lead.whatsapp &&
                    normalizeText(lead.whatsapp).includes(query)) ||
                (lead.company && normalizeText(lead.company).includes(query)) ||
                (lead.service && normalizeText(lead.service).includes(query)) ||
                (lead.goal && normalizeText(lead.goal).includes(query)) ||
                (lead.need && normalizeText(lead.need).includes(query));

            const matchesStatus =
                statusFilter === "all" || lead.status === statusFilter;

            return matchesSearch && matchesStatus;
        });

        const totalFiltered = filteredLeads.length;
        const totalPages = Math.ceil(totalFiltered / leadsPerPage) || 1;

        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;

        const start = totalFiltered > 0 ? (currentPage - 1) * leadsPerPage : 0;
        const end = Math.min(start + leadsPerPage, totalFiltered);
        const paginatedLeads = filteredLeads.slice(start, end);

        if (totalCountEl)
            totalCountEl.textContent = leadsData.length.toString();
        if (filteredCountEl)
            filteredCountEl.textContent = totalFiltered.toString();
        if (pageRangeEl)
            pageRangeEl.textContent =
                totalFiltered > 0 ? `${start + 1}-${end}` : "0-0";

        if (leadsContainerMobile) leadsContainerMobile.innerHTML = "";
        const desktopTbody = leadsContainerDesktop;
        if (desktopTbody) desktopTbody.innerHTML = "";

        if (totalFiltered === 0) {
            noLeadsEl?.classList.remove("hidden");
            paginationControls?.classList.add("hidden");
        } else {
            noLeadsEl?.classList.add("hidden");
            paginationControls?.classList.remove("hidden");

            paginatedLeads.forEach((lead) => {
                if (leadsContainerMobile)
                    leadsContainerMobile.appendChild(createLeadCard(lead));
                if (desktopTbody) desktopTbody.appendChild(createLeadRow(lead));
            });
        }

        renderPagination(totalPages);
        setupListeners();
    };

    const createLeadCard = (lead: any) => {
        const div = document.createElement("div");
        div.className =
            "lead-card bg-white p-5 rounded-2xl border border-neutral-100 shadow-sm space-y-4";
        div.setAttribute("data-id", lead.id);
        const dateStr = new Date(lead.created_at).toLocaleString();
        const statusClass =
            lead.status === "pending"
                ? "bg-orange-100 text-[#FF8A00]"
                : lead.status === "contacted"
                  ? "bg-green-100 text-green-600"
                  : "bg-neutral-100 text-neutral-400";
        const statusText =
            lead.status === "pending"
                ? "Pendiente"
                : lead.status === "contacted"
                  ? "Contactado"
                  : "Descartado";

        div.innerHTML = `
            <div class="flex justify-between items-start">
                <div>
                    <h3 class="font-bold text-neutral-800 lead-name-display">${lead.name}</h3>
                    <p class="text-xs text-neutral-400">${dateStr}</p>
                </div>
                <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider status-badge ${statusClass}">${statusText}</span>
            </div>
            <div class="space-y-2 text-sm">
                <div class="flex items-center gap-2 text-neutral-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.94 3.659 1.437 5.63 1.438h.001c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                    </svg>
                    <a href="https://wa.me/${(lead.whatsapp || lead.phone || "").replace(/[^0-9]/g, "")}" target="_blank" class="hover:text-[#FF8A00] transition-colors font-bold">${lead.whatsapp || lead.phone || "-"}</a>
                    <span class="text-[10px] text-neutral-400 uppercase">${lead.country_code || ""}</span>
                </div>
                <div class="text-neutral-600 flex flex-col gap-1">
                    <div class="flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-orange-400"></span>
                        <span class="font-bold text-neutral-800">${lead.service || "Sin servicio"}</span>
                    </div>
                    <p class="text-xs text-neutral-500 italic ml-3">"${lead.goal || "Sin objetivo detectado"}"</p>
                </div>
            </div>
            <div class="pt-4 border-t border-neutral-50 flex justify-between items-center">
                <select class="update-status text-xs border-none bg-neutral-50 rounded-lg px-2 py-1 focus:ring-0 text-neutral-500 font-medium cursor-pointer" data-id="${lead.id}">
                    <option value="pending" ${lead.status === "pending" ? "selected" : ""}>Pendiente</option>
                    <option value="contacted" ${lead.status === "contacted" ? "selected" : ""}>Contactado</option>
                    <option value="discarded" ${lead.status === "discarded" ? "selected" : ""}>Descartado</option>
                </select>
                <div class="flex gap-2">
                    <button class="edit-lead p-2 bg-neutral-50 text-neutral-400 rounded-lg hover:text-[#FF8A00] cursor-pointer" data-id="${lead.id}">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                    </button>
                    <button class="delete-lead p-2 bg-red-50 text-red-400 rounded-lg hover:bg-red-500 hover:text-white cursor-pointer" data-id="${lead.id}">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            </div>
        `;
        return div;
    };

    const createLeadRow = (lead: any) => {
        const tr = document.createElement("tr");
        tr.className =
            "border-b border-neutral-50 hover:bg-neutral-50/50 transition-colors group";
        tr.setAttribute("data-id", lead.id);
        const dateStr = new Date(lead.created_at).toLocaleDateString();
        const statusClass =
            lead.status === "pending"
                ? "bg-orange-100 text-[#FF8A00]"
                : lead.status === "contacted"
                  ? "bg-green-100 text-green-600"
                  : "bg-neutral-100 text-neutral-400";
        const statusText =
            lead.status === "pending"
                ? "Pendiente"
                : lead.status === "contacted"
                  ? "Contactado"
                  : "Descartado";
        const sourceIcon = lead.source === "wizard" ? "🤖" : "✉️";

        tr.innerHTML = `
            <td class="px-6 py-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-neutral-100 flex items-center justify-center font-bold text-neutral-400 uppercase">${lead.name.charAt(0)}</div>
                    <div>
                        <div class="font-bold text-neutral-800 lead-name-display">${lead.name}</div>
                        <div class="text-xs text-neutral-400 flex items-center gap-1">
                            ${sourceIcon} ${dateStr}
                        </div>
                    </div>
                </div>
            </td>
            <td class="px-6 py-5">
                <div class="flex flex-col gap-1">
                    <a href="https://wa.me/${(lead.whatsapp || lead.phone || "").replace(/[^0-9]/g, "")}" target="_blank" class="text-sm font-bold text-neutral-700 hover:text-[#FF8A00] transition-colors flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.94 3.659 1.437 5.63 1.438h.001c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                        ${lead.whatsapp || lead.phone || "-"}
                    </a>
                    <div class="text-[10px] text-neutral-400 flex items-center gap-2">
                        <span>${lead.email || "-"}</span>
                        ${lead.country_code ? `<span class="bg-neutral-100 px-1 rounded font-bold">${lead.country_code}</span>` : ""}
                    </div>
                </div>
            </td>
            <td class="px-6 py-5">
                <div class="flex flex-col">
                    <span class="text-sm font-bold text-neutral-700">${lead.service || "General"}</span>
                    <span class="text-xs text-neutral-400 truncate max-w-[150px]" title="${lead.goal || ""}">${lead.goal || "-"}</span>
                </div>
            </td>
            <td class="px-6 py-5">
                <div class="flex flex-col">
                    <span class="text-sm text-neutral-600">${lead.company || "-"}</span>
                    <span class="text-[10px] text-neutral-400 uppercase tracking-tighter">${lead.business_type || "No especificado"}</span>
                </div>
            </td>
            <td class="px-6 py-5">
                <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider status-badge ${statusClass}">${statusText}</span>
            </td>
            <td class="px-6 py-5">
                <select class="update-status w-full text-xs border-neutral-100 bg-neutral-50 rounded-xl px-3 py-2 focus:ring-0 focus:border-orange-200 text-neutral-500 font-medium cursor-pointer" data-id="${lead.id}">
                    <option value="pending" ${lead.status === "pending" ? "selected" : ""}>Pendiente</option>
                    <option value="contacted" ${lead.status === "contacted" ? "selected" : ""}>Contactado</option>
                    <option value="discarded" ${lead.status === "discarded" ? "selected" : ""}>Descartado</option>
                </select>
            </td>
            <td class="px-6 py-5 text-right">
                <div class="flex justify-end gap-2">
                    <button class="edit-lead p-2.5 bg-neutral-50 text-neutral-400 rounded-xl hover:bg-orange-50 hover:text-[#FF8A00] transition-all cursor-pointer" data-id="${lead.id}">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                    </button>
                    <button class="delete-lead p-2.5 bg-red-50 text-red-500 rounded-xl hover:bg-red-500 hover:text-white transition-all cursor-pointer" data-id="${lead.id}">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            </td>
        `;
        return tr;
    };

    const renderPagination = (totalPages: number) => {
        if (prevPageBtn) prevPageBtn.disabled = currentPage === 1;
        if (nextPageBtn)
            nextPageBtn.disabled =
                currentPage === totalPages || totalPages === 0;
        if (pageNumbersContainer) {
            pageNumbersContainer.innerHTML = "";
            const maxVisible = 5;
            let start = Math.max(1, currentPage - 2);
            let end = Math.min(totalPages, start + maxVisible - 1);
            if (end - start < maxVisible - 1)
                start = Math.max(1, end - maxVisible + 1);

            for (let i = start; i <= end; i++) {
                const btn = document.createElement("button");
                btn.className = `w-8 h-8 flex items-center justify-center rounded-lg text-sm font-bold transition-all ${i === currentPage ? "bg-[#FF8A00] text-white shadow-md shadow-orange-100" : "text-neutral-400 hover:bg-neutral-50 hover:text-neutral-600"}`;
                btn.textContent = i.toString();
                btn.onclick = () => {
                    currentPage = i;
                    renderLeads();
                };
                pageNumbersContainer.appendChild(btn);
            }
        }
    };

    const setupListeners = () => {
        // Status Filter Buttons
        document.querySelectorAll(".status-filter").forEach((btn: any) => {
            btn.onclick = () => {
                document.querySelectorAll(".status-filter").forEach((b) => {
                    b.classList.remove(
                        "active",
                        "bg-[#FF8A00]",
                        "text-white",
                        "shadow-xl",
                        "shadow-orange-100",
                        "border-transparent",
                    );
                    b.classList.add(
                        "bg-white",
                        "text-neutral-400",
                        "border-neutral-50",
                    );
                });
                btn.classList.add(
                    "active",
                    "bg-[#FF8A00]",
                    "text-white",
                    "shadow-xl",
                    "shadow-orange-100",
                    "border-transparent",
                );
                btn.classList.remove(
                    "bg-white",
                    "text-neutral-400",
                    "border-neutral-50",
                );

                statusFilter = btn.dataset.status;
                currentPage = 1;
                renderLeads();
            };
        });

        document.querySelectorAll(".update-status").forEach((el) =>
            el.addEventListener("change", async (e: any) => {
                const id = e.target.dataset.id;
                const status = e.target.value;

                // Optimistic Update
                leadsData = leadsData.map((l: any) =>
                    l.id === id ? { ...l, status } : l,
                );
                renderLeads();

                const { error } = await supabase
                    .from("leads")
                    .update({ status })
                    .eq("id", id);
                if (error) {
                    alert("Error al actualizar estado");
                    // Revert if error? (Optional but good)
                }
            }),
        );
        document.querySelectorAll(".delete-lead").forEach((el) =>
            el.addEventListener("click", async (e: any) => {
                const id = e.currentTarget.dataset.id;
                if (confirm("¿Eliminar permanentemente?"))
                    await supabase.from("leads").delete().eq("id", id);
            }),
        );
        document.querySelectorAll(".edit-lead").forEach((el) =>
            el.addEventListener("click", async (e: any) => {
                const id = e.currentTarget.dataset.id;
                const { data } = await supabase
                    .from("leads")
                    .select("*")
                    .eq("id", id)
                    .single();
                if (data) openModal(data);
            }),
        );
    };

    const openModal = (lead: any = null) => {
        isEditing = !!lead;
        if (modalTitle)
            modalTitle.textContent = isEditing
                ? "Editar Lead"
                : "Añadir Nuevo Lead";
        if (saveBtnText)
            saveBtnText.textContent = isEditing
                ? "Actualizar Cambios"
                : "Guardar Lead";
        if (lead) {
            const data = extractLeadData(lead);
            const setVal = (name: string, val: string) => {
                const el = leadForm?.elements.namedItem(name) as
                    | HTMLInputElement
                    | HTMLTextAreaElement;
                if (el) el.value = val;
            };

            setVal("id", data.id);
            setVal("name", data.name);
            setVal("phone", data.phone || "");
            setVal("whatsapp", data.whatsapp || "");
            setVal("email", data.email || "");
            setVal("company", data.company || "");
            setVal("service", data.service || "");
            setVal("goal", data.goal || "");
            setVal("business_type", data.business_type || "");
            setVal("country_code", data.country_code || "");
            setVal("need", data.need || "");
            setVal("message", data.message || "");
        } else {
            leadForm?.reset();
            (leadForm?.elements.namedItem("id") as HTMLInputElement).value = "";
        }
        modal?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
        modal?.classList.add("hidden");
        document.body.style.overflow = "auto";
    };

    // Event Bindings
    document
        .getElementById("add-lead-btn")
        ?.addEventListener("click", () => openModal());
    document
        .getElementById("close-modal")
        ?.addEventListener("click", closeModal);
    document
        .getElementById("cancel-modal")
        ?.addEventListener("click", closeModal);
    prevPageBtn?.addEventListener("click", () => {
        if (currentPage > 1) {
            currentPage--;
            renderLeads();
        }
    });
    nextPageBtn?.addEventListener("click", () => {
        currentPage++;
        renderLeads();
    });
    searchInput?.addEventListener(
        "input",
        debounce(() => {
            currentPage = 1;
            renderLeads();
        }, 300),
    );

    leadForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(leadForm);
        const payload = {
            name: formData.get("name"),
            phone: formData.get("phone"),
            whatsapp: formData.get("whatsapp"),
            email: formData.get("email"),
            company: formData.get("company"),
            service: formData.get("service"),
            goal: formData.get("goal"),
            business_type: formData.get("business_type"),
            country_code: formData.get("country_code"),
            need: formData.get("need"),
            message: formData.get("message"),
            source: isEditing ? undefined : "contact_form",
            status: isEditing ? undefined : "pending",
        };
        const saveBtn = document.getElementById(
            "save-lead-btn",
        ) as HTMLButtonElement;
        if (saveBtn) saveBtn.disabled = true;
        if (saveBtnText) saveBtnText.textContent = "Guardando...";

        try {
            if (isEditing) {
                const { error } = await supabase
                    .from("leads")
                    .update(payload)
                    .eq("id", formData.get("id"));
                if (error) throw error;
            } else {
                const { error } = await supabase
                    .from("leads")
                    .insert([payload]);
                if (error) throw error;
            }
            closeModal();
        } catch (err: any) {
            alert("Error: " + err.message);
        } finally {
            if (saveBtn) saveBtn.disabled = false;
            if (saveBtnText)
                saveBtnText.textContent = isEditing
                    ? "Actualizar Cambios"
                    : "Guardar Lead";
        }
    });

    document
        .getElementById("logout-btn")
        ?.addEventListener("click", async () => {
            await supabase.auth.signOut();
            document.cookie =
                "sb-access-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC";
            document.cookie =
                "sb-refresh-token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC";
            window.location.href = "/login";
        });

    // Real-time
    const channel = supabase
        .channel("leads-all")
        .on(
            "postgres_changes",
            { event: "*", schema: "public", table: "leads" },
            (payload) => {
                if (payload.eventType === "INSERT") {
                    leadsData = [payload.new, ...leadsData];
                } else if (payload.eventType === "UPDATE") {
                    leadsData = leadsData.map((l: any) =>
                        l.id === payload.new.id ? payload.new : l,
                    );
                } else if (payload.eventType === "DELETE") {
                    leadsData = leadsData.filter(
                        (l: any) => l.id !== payload.old.id,
                    );
                }
                renderLeads();
            },
        )
        .subscribe();

    // Reload leads
    const reloadLeads = async () => {
        const btn = document.getElementById("reload-btn");
        const svg = btn?.querySelector("svg");
        if (svg) svg.classList.add("animate-spin");

        const { data, error } = await supabase
            .from("leads")
            .select("*")
            .order("created_at", { ascending: false });

        if (error) {
            console.error("Error reloading leads:", error);
        } else {
            leadsData = data || [];
            renderLeads();
        }

        if (svg) {
            setTimeout(() => {
                svg.classList.remove("animate-spin");
            }, 500);
        }
    };

    document
        .getElementById("reload-btn")
        ?.addEventListener("click", reloadLeads);

    // Initial Render
    renderLeads();
</script>

<style is:global>
    @page {
        @top-center {
            content: "Ganex Admin Panel";
        }
    }
    #lead-modal:not(.hidden) > div {
        animation: modalScale 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes modalScale {
        from {
            opacity: 0;
            transform: scale(0.95);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>
