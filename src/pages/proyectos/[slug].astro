---
import Layout from "../../layouts/Layout.astro";
import { siteData } from "../../data/siteData";
import Header from "../../components/Header.astro";
import Image from "astro/components/Image.astro";

export const prerender = true;

export async function getStaticPaths() {
  return siteData.portfolio.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Ganex Portfolio`}>
  <div class="bg-neutral-900">
    <Header />
  </div>
  <div class="pt-32 pb-12 bg-linear-to-br from-neutral-50 to-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <a
          href="/#portafolio"
          class="inline-flex items-center text-[#FF8A00] font-bold mb-8 hover:underline"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 mr-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Volver al portafolio
        </a>

        <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
          <div class="relative h-64 sm:h-96 bg-neutral-200">
            {/* Image Placeholder or Actual Image */}
            <div
              class="absolute inset-0 flex items-center justify-center bg-neutral-100 text-neutral-300"
            >
              <!-- <svg
                class="w-32 h-32"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg> -->
              <Image
                src={project.image}
                alt={project.title}
                width={600}
                height={400}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
            </div>
            <div
              class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent"
            >
            </div>
            <div class="absolute bottom-0 left-0 p-8 sm:p-12">
              <span
                class="bg-[#FF8A00] text-white px-4 py-1 rounded-full text-sm font-bold tracking-wide uppercase mb-4 inline-block"
              >
                {project.category}
              </span>
              <h1 class="text-4xl sm:text-5xl font-bold text-white">
                {project.title}
              </h1>
            </div>
          </div>

          <div class="p-8 sm:p-12">
            <div class="prose prose-lg max-w-none text-neutral-600">
              <h3 class="text-2xl font-bold text-neutral-800 mb-4">
                Sobre el proyecto
              </h3>
              <p class="mb-8 leading-relaxed">
                {project.details || project.description}
              </p>

              <div class="border-t border-neutral-100 pt-8 mt-8">
                <h4 class="text-lg font-bold text-neutral-800 mb-2">
                  Descripción Corta
                </h4>
                <p>{project.description}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
