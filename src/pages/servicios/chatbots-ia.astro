---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Contact from "../../components/Contact.astro";
---

<Layout>
  <div class="bg-neutral-900">
    <Header />
  </div>
  <main class="max-w-7xl mx-auto px-4 py-20 text-neutral-800 bg-white">
    <h1 class="text-5xl font-bold mb-10 text-center text-[#FF8A00]">
      Chatbots con IA
    </h1>
    <p class="text-xl text-center max-w-3xl mx-auto mb-16">
      Automatización y atención al cliente inteligente.
    </p>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl font-bold text-neutral-800">
          El futuro de la atención al cliente
        </h2>
        <p class="text-neutral-600 leading-relaxed">
          Integra inteligencia artificial en tu negocio para ofrecer respuestas
          instantáneas y personalizadas las 24 horas del día. Optimiza tus
          procesos y libera a tu equipo para tareas más estratégicas.
        </p>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <svg
              class="w-6 h-6 text-[#FF8A00]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span class="text-neutral-700"
              >Atención 24/7 sin interrupciones</span
            >
          </li>
          <li class="flex items-center gap-3">
            <svg
              class="w-6 h-6 text-[#FF8A00]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span class="text-neutral-700"
              >Procesamiento de Lenguaje Natural (NLP)</span
            >
          </li>
          <li class="flex items-center gap-3">
            <svg
              class="w-6 h-6 text-[#FF8A00]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span class="text-neutral-700"
              >Integración con CRM y Bases de Datos</span
            >
          </li>
        </ul>
      </div>
      <div
        class="bg-orange-50 rounded-2xl p-8 flex items-center justify-center min-h-75"
      >
        <svg
          class="w-32 h-32 text-[#FF8A00] opacity-50"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1"
            d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
          ></path>
        </svg>
      </div>
    </div>
  </main>
  <Contact />
</Layout>
